generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserQuota {
  clerk_user_id       String   @id @map("clerk_user_id")
  document_quota_left Int      @default(2) @map("document_quota_left")
  documents_analysed  Int      @default(0) @map("documents_analysed")
  created_at          DateTime @default(now()) @map("created_at")
  updated_at          DateTime @updatedAt @map("updated_at")

  @@map("user_queries")
}

model AlipayOrder {
  id            String   @id @default(cuid())
  outTradeNo    String   @unique @map("out_trade_no")
  alipayTradeNo String   @unique @map("alipay_trade_no")
  clerkUserId   String   @map("clerk_user_id")
  tokenCount    Int
  amount        Float
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("alipay_orders")
}
